{
  "name": "@chicowall/capacitor-appfunctions",
  "version": "0.1.1",
  "description": "Plugin Capacitor que expoe acoes do agendaAI como Android AppFunctions para o Gemini",
  "main": "dist/plugin.cjs.js",
  "module": "dist/esm/index.js",
  "types": "dist/esm/index.d.ts",
  "unpkg": "dist/plugin.js",
  "files": [
    "android/src/main/",
    "android/build.gradle",
    "dist/",
    "AgendaaiCapacitorAppfunctions.podspec"
  ],
  "author": "agendaAI",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/FranciscoWallison/capacitor-appfunctions.git"
  },
  "bugs": {
    "url": "https://github.com/FranciscoWallison/capacitor-appfunctions/issues"
  },
  "homepage": "https://github.com/FranciscoWallison/capacitor-appfunctions#readme",
  "scripts": {
    "verify": "npm run verify:android && npm run verify:web",
    "verify:android": "cd android && ./gradlew clean build test && cd ..",
    "verify:web": "npm run build",
    "lint": "npm run eslint && npm run prettier -- --check",
    "fmt": "npm run eslint -- --fix && npm run prettier -- --write",
    "eslint": "eslint . --ext ts",
    "prettier": "prettier \"**/*.{css,html,ts,js,java}\"",
    "docgen": "docgen --api AgendaAIAppFunctionsPlugin --output-readme README.md --output-json dist/docs.json",
    "build": "npm run clean && npm run docgen && tsc && rollup -c rollup.config.mjs",
    "clean": "rimraf ./dist"
  },
  "devDependencies": {
    "@capacitor/android": "^8.0.0",
    "@capacitor/core": "^8.0.0",
    "@capacitor/docgen": "^0.3.0",
    "@ionic/eslint-config": "^0.4.0",
    "@ionic/prettier-config": "^4.0.0",
    "@ionic/swiftlint-config": "^2.0.0",
    "@types/node": "^24.0.0",
    "eslint": "^8.57.0",
    "prettier": "^3.4.2",
    "rimraf": "^6.0.1",
    "rollup": "^4.30.0",
    "typescript": "^5.7.3"
  },
  "peerDependencies": {
    "@capacitor/core": "^8.0.0"
  },
  "capacitor": {
    "android": {
      "src": "android"
    }
  },
  "prettier": "@ionic/prettier-config",
  "eslintConfig": {
    "extends": "@ionic/eslint-config/recommended"
  },
  "swiftlint": "@ionic/swiftlint-config"
}
